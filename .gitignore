# Dependency directories
node_modules/
client/node_modules/
server/node_modules/

# Local database files (SQLite)
server/prisma/*.db
server/prisma/*.db-journal

# Environment variables (contains private credentials)
.env
server/.env
client/.env
client/.env.local
client/.env.development.local
client/.env.test.local
client/.env.production.local

# Production Build output
client/dist/

# Local uploads and assets (uploaded by users during local run)
server/uploads/*
!server/uploads/.gitkeep

# System files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
